# Copy this file as .env and fill in the real values
# NEVER commit .env to the repository

# ── Firebird ERP (Flexxus) ─────────────────────────────────
FB_HOST=127.0.0.1
FB_PORT=3050
FB_USER=SYSDBA
FB_PASS=

# ── Firebird Databases ─────────────────────────────────────
DB_L1=c:/flexxus/DB/DB-Microbell.gdb
DB_EST=c:/flexxus/DB/DB-EST-Microbell.gdb
DB_MLT=c:/flexxus/DB/DB-MLT-Microbell.gdb

# ── SMTP (Gmail recommended) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TO_PAGOS=payments@yourcompany.com

# ── Catalogs ───────────────────────────────────────────────
CATALOGOS_DIR=catalogos

# ── WhatsApp Business — Meta Cloud API ────────────────────
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_WABA_ID=
WA_TEMPLATE_CAT=microbell_catalogo

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=generate_a_random_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=10

# ── OneSignal Push Notifications ──────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
